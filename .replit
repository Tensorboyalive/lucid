run = "npm run dev -- --hostname 0.0.0.0 --port 3000"
modules = ["nodejs-20", "python-3.11"]
hidden = [".next", "node_modules"]

[env]
NEXT_TELEMETRY_DISABLED = "1"
HOST = "0.0.0.0"
PORT = "3000"

[deployment]
deploymentTarget = "autoscale"
run = ["sh", "-c", "npm run start -- --hostname 0.0.0.0 --port 3000"]
build = ["sh", "-c", "npm install && npm run build"]
ignorePorts = false

[[ports]]
localPort = 5000
externalPort = 80

[nix]
channel = "stable-24_05"

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 180000
