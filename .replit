run = "npm run dev -- --hostname 0.0.0.0 --port 3000"
modules = ["nodejs-20", "python-3.11"]
hidden = [".next", "node_modules"]

[env]
NEXT_TELEMETRY_DISABLED = "1"
HOST = "0.0.0.0"
PORT = "3000"

[deployment]
deploymentTarget = "autoscale"
run = ["sh", "-c", "npm run start -- --hostname 0.0.0.0 --port 3000"]
build = ["sh", "-c", "npm install && npm run build"]
ignorePorts = false

[[ports]]
localPort = 3000
externalPort = 80

[nix]
channel = "stable-24_05"
