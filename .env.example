# lucid. copy to .env.local and fill in. add each to Vercel project env vars for deploy.

# ─── language engine (required) ──────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# ─── scene + emotion engine (optional) ───────────────────────────────────────
GEMINI_API_KEY=

# ─── creator ingest (optional) ───────────────────────────────────────────────
APIFY_TOKEN=

# ─── database (optional) ─────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── optional language model fallback ────────────────────────────────────────
OPENAI_API_KEY=

# ─── neuro engine hand-off (optional) ────────────────────────────────────────
# Absolute path to the Python engine if running the full Alpha inference
# pipeline locally. In the web product we ship cached inference from
# prior GPU runs; leaving this empty activates the authored demo path.
NEURO_ENGINE_PATH=

# ─── deploy mode (optional) ──────────────────────────────────────────────────
# Set to "true" on the public / pre-launch Vercel project. Middleware then
# redirects /score, /research, /rewrite, /business → /waitlist, and the nav
# and hero CTAs rewrite themselves to funnel into the waitlist. Leave unset
# on the private / full-product project.
NEXT_PUBLIC_PUBLIC_ONLY=

# ─── slack waitlist notifications (optional) ─────────────────────────────────
# Incoming webhook that pings a channel on every new signup so you see the
# list grow in real time. Leave empty to disable.
SLACK_WAITLIST_WEBHOOK=
